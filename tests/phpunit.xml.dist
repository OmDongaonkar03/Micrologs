<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.5/phpunit.xsd"
         bootstrap="bootstrap.php"
         colors="true"
         stopOnFailure="false"
         failOnWarning="false"
         displayDetailsOnTestsThatTriggerWarnings="true"
         displayDetailsOnTestsThatTriggerErrors="true">

    <testsuites>
        <testsuite name="api">
            <directory>api</directory>
        </testsuite>
        <testsuite name="workers">
            <directory>workers</directory>
        </testsuite>
        <testsuite name="all">
            <directory>api</directory>
            <directory>workers</directory>
        </testsuite>
    </testsuites>

    <coverage>
        <report>
            <html outputDirectory="coverage"/>
        </report>
    </coverage>

    <php>
        <env name="ML_TEST_DB_HOST" value="your_db_host_here"/>
        <env name="ML_TEST_DB_USER" value="your_db_user_here"/>
        <env name="ML_TEST_DB_PASS" value="your_db_pass_here"/>
        <env name="ML_TEST_URL" value="your_test_url_here"/>
        <env name="ML_TEST_ADMIN_KEY" value="your_admin_key_here"/>
        <env name="ML_TEST_VALKEY_HOST" value="your_valkey_host_here"/>
        <env name="ML_TEST_VALKEY_PORT" value="your_valkey_port_here"/>
        <env name="ML_TEST_MODE" value="true"/>
    </php>
</phpunit>
